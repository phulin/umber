+@ The profiling build records the first execution of each primitive meaning.
+Aliases created with \.{\\let} are folded onto an original primitive with the
+same command and operand. The trace is deliberately a presence set rather
+than a frequency counter: document prevalence is the useful corpus metric,
+and emitting only first use keeps ordinary jobs small.
+
+@p procedure trace_primitive_execution;
+label found,done;
+var @!slot,@!first_slot:0..4092;
+@!p:pointer;
+begin
+if cur_cs=0 then goto done;
+slot:=(cur_cmd*257+cur_chr) mod 4093;
+first_slot:=slot;
+while primitive_trace_prim[slot]<>undefined_primitive do
+  begin
+  if (primitive_trace_cmd[slot]=cur_cmd)and
+     (primitive_trace_chr[slot]=cur_chr) then goto done;
+  slot:=(slot+1) mod 4093;
+  if slot=first_slot then goto done;
+  end;
+if (cur_cs>=prim_eqtb_base)and(cur_cs<frozen_null_font) then
+  begin
+  p:=cur_cs-prim_eqtb_base;
+  if (prim_eq_type(p)=cur_cmd)and(prim_equiv(p)=cur_chr) then goto found;
+  end;
+for p:=1 to prim_size do
+  if (prim_text(p)>0)and(prim_eq_type(p)=cur_cmd)and
+     (prim_equiv(p)=cur_chr) then goto found;
+goto done;
+found:
+primitive_trace_cmd[slot]:=cur_cmd;
+primitive_trace_chr[slot]:=cur_chr;
+primitive_trace_prim[slot]:=p;
+print_nl("PDFTEX_PRIMITIVE_USED ");
+print_char(@'134); print(prim_text(p)-1);
+print_ln;
+done:
+end;
+
